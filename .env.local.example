## Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

## OpenAI (SOP parsing + transcription)
OPENAI_API_KEY=sk-...

## Anthropic (adversarial SOP verification)
ANTHROPIC_API_KEY=sk-ant-...

## Shotstack (video SOP generation)
SHOTSTACK_API_KEY=your-shotstack-key
# Sandbox URL for testing (free, watermarked). Omit or set to https://api.shotstack.io/edit/v1 for production.
SHOTSTACK_API_URL=https://api.shotstack.io/edit/stage

# Phase 12.5 — Deepgram streaming transcription (server-only; never NEXT_PUBLIC_*)
# Required for voice capture (SB-UX-06). Scope: /v1/auth/grant + /v1/listen.
# Get a key from https://console.deepgram.com/ → API Keys.
DEEPGRAM_API_KEY=

# Phase 12.5 — ModelBlock 3D viewer feature flag (client-readable)
# Default: false — renders a placeholder. Set to "true" to enable the
# (currently stubbed) 3D viewer once Phase 12.6 lands.
NEXT_PUBLIC_MODEL_BLOCK_ENABLED=false
